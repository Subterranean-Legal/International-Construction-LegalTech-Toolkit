技术层

盾构穿越‘承压含水层’或‘砂卵石地层’时，若仓压控制失当或地层突变（如暗浜、古河道），可能发生‘涌水涌砂’，导致：

- 盾构被迫停机（工期中断）
- 刀盘磨损或卡机
- 地面塌陷（需紧急处置）

判断关键：是否属于"有经验承包商不可预见"的地质突变。
⚖️ 法律层
```
盾构涌水涌砂
  ├─ 若地勘已揭示该含水层
  │     → 承包商"应当预见" → 自身风险
  │     → 无Cl.4.12索赔权利
  │
  ├─ 若为未揭示的古河道/暗浜
  │     → Cl.4.12 不可预见 → Cost + EOT ✅
  │
  └─ 若发生地面塌陷危及公众安全
        → Cl.19.1 Force Majeure（不可抗力）
              条件：外部的、不可预见的、不可避免的
        → 双方各自承担自身损失
        → 承包商仍可获 EOT（Cl.19.4）
        → 但不获额外 Cost（除人员救援费用）
        # fidic_toolkit/tbm_groundwater_risk_classifier.py
# FIDIC Red Book 1999 — TBM Water Inrush: Cl.4.12 vs Cl.19.1 Classifier
# Technical: Groundwater event → Legal: liability pathway → Code: classifier

from dataclasses import dataclass
from enum import Enum

class InrushCause(Enum):
    DISCLOSED_AQUIFER    = "Aquifer disclosed in Employer's geotech report"
    UNDISCLOSED_FEATURE  = "Undisclosed palaeochannel / hidden aquifer"
    EXTREME_RAINFALL     = "Extreme rainfall event (meteorological)"
    CONTRACTOR_ERROR     = "Contractor's face pressure mismanagement"

class FIDICPathway(Enum):
    CL_4_12_COST_EOT     = "Cl.4.12 — Unforeseeable: Cost + Profit + EOT"
    CL_19_1_EOT_ONLY     = "Cl.19.1 Force Majeure — EOT only, no Cost"
    CONTRACTOR_RISK      = "Contractor's risk — no entitlement"
    CL_4_12_INVESTIGATE  = "Potential Cl.4.12 — further evidence required"

@dataclass
class TBMInrushEvent:
    chainage_m: float
    inrush_cause: InrushCause
    disclosed_in_geotech_report: bool
    experienced_contractor_foreseeable: bool
    public_safety_risk: bool          # Ground collapse threatening public
    notice_issued_cl20_1: bool
    stoppage_days: int

def classify_inrush_claim(event: TBMInrushEvent) -> dict:
    """
    Classifies TBM water inrush event into FIDIC liability pathway.
    
    Decision logic:
    1. Contractor error → no claim
    2. Disclosed aquifer → contractor's risk (should have priced it)
    3. Undisclosed + unforeseeable + public risk → Cl.19.1 EOT only
    4. Undisclosed + unforeseeable + no public risk → Cl.4.12 Cost+EOT
    5. Ambiguous → flag for further investigation
    """
    result = {
        "chainage_m"      : event.chainage_m,
        "inrush_cause"    : event.inrush_cause.value,
        "fidic_pathway"   : None,
        "eot_days"        : 0,
        "cost_recoverable": False,
        "profit_applicable": False,
        "warnings"        : []
    }

    # Gate 1: Contractor fault
    if event.inrush_cause == InrushCause.CONTRACTOR_ERROR:
        result["fidic_pathway"] = FIDICPathway.CONTRACTOR_RISK.value
        result["warnings"].append("Contractor face pressure records to be audited.")
        return result

    # Gate 2: Was it disclosed?
    if event.disclosed_in_geotech_report or event.experienced_contractor_foreseeable:
        result["fidic_pathway"] = FIDICPathway.CONTRACTOR_RISK.value
        result["warnings"].append(
            "Condition was foreseeable — Cl.4.12 claim basis absent. "
            "Review risk allocation in contract Appendix."
        )
        return result

    # Gate 3: Undisclosed — is it Force Majeure scale?
    if event.public_safety_risk and event.inrush_cause == InrushCause.EXTREME_RAINFALL:
        result["fidic_pathway"]    = FIDICPathway.CL_19_1_EOT_ONLY.value
        result["eot_days"]         = event.stoppage_days
        result["cost_recoverable"] = False
        result["warnings"].append(
            "Cl.19.3: Notice of force majeure required within 14 days."
        )
        return result

    # Gate 4: Undisclosed, unforeseeable → Cl.4.12
    if not event.notice_issued_cl20_1:
        result["warnings"].append(
            "CRITICAL: Cl.20.1 notice not issued — 28-day time-bar risk."
        )

    result["fidic_pathway"]     = FIDICPathway.CL_4_12_COST_EOT.value
    result["eot_days"]          = event.stoppage_days
    result["cost_recoverable"]  = event.notice_issued_cl20_1
    result["profit_applicable"] = event.notice_issued_cl20_1
    result["entitlements"] = [
        f"EOT: {event.stoppage_days} days (Cl.8.4(b))",
        "Additional Cost: TBM stoppage + grouting works (Cl.4.12)",
        "Profit on Cost (Cl.4.12 ¶4)"
    ]

    return result


# ── Demo: Metro shield tunnel, soft ground with hidden palaeochannel ─
if __name__ == "__main__":
    import json

    event = TBMInrushEvent(
        chainage_m=1240,
        inrush_cause=InrushCause.UNDISCLOSED_FEATURE,
        disclosed_in_geotech_report=False,
        experienced_contractor_foreseeable=False,
        public_safety_risk=False,
        notice_issued_cl20_1=True,
        stoppage_days=18
    )

    result = classify_inrush_claim(event)
    print(json.dumps(result, ensure_ascii=False, indent=2))
